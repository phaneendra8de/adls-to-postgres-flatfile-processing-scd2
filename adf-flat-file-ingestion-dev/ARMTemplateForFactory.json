{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-flat-file-ingestion-dev"
		},
		"ls_adls_ingestion_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ls_adls_ingestion'"
		},
		"ls_postgres_ingestion_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_postgres_ingestion'"
		},
		"ls_adls_ingestion_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://stphdplatdevcin01.dfs.core.windows.net/"
		},
		"ls_postgres_ingestion_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "psql-phani-deplatform-dev-cin-01.postgres.database.azure.com"
		},
		"ls_postgres_ingestion_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "postgres"
		},
		"ls_postgres_ingestion_properties_typeProperties_username": {
			"type": "string",
			"defaultValue": "adminuser"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "[concat(parameters('factoryName'), '/ds_adls_csv_ingest_source')]",
			"type": "Microsoft.DataFactory/factories/datasets",
			"apiVersion": "2018-06-01",
			"properties": {
				"linkedServiceName": {
					"referenceName": "ls_adls_ingestion",
					"type": "LinkedServiceReference"
				},
				"parameters": {
					"p_source_container": {
						"type": "string"
					},
					"p_source_directory": {
						"type": "string"
					},
					"p_file_name": {
						"type": "string"
					}
				},
				"annotations": [],
				"type": "DelimitedText",
				"typeProperties": {
					"location": {
						"type": "AzureBlobFSLocation",
						"fileName": {
							"value": "@dataset().p_file_name",
							"type": "Expression"
						},
						"folderPath": {
							"value": "@dataset().p_source_directory",
							"type": "Expression"
						},
						"fileSystem": {
							"value": "@dataset().p_source_container",
							"type": "Expression"
						}
					},
					"columnDelimiter": ",",
					"escapeChar": "\\",
					"firstRowAsHeader": true,
					"quoteChar": "\""
				},
				"schema": []
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/linkedServices/ls_adls_ingestion')]"
			]
		},
		{
			"name": "[concat(parameters('factoryName'), '/ds_adls_parquet_ingest_bronze')]",
			"type": "Microsoft.DataFactory/factories/datasets",
			"apiVersion": "2018-06-01",
			"properties": {
				"linkedServiceName": {
					"referenceName": "ls_adls_ingestion",
					"type": "LinkedServiceReference"
				},
				"parameters": {
					"p_target_container": {
						"type": "string"
					},
					"p_target_directory": {
						"type": "string"
					},
					"p_file_name": {
						"type": "string"
					}
				},
				"annotations": [],
				"type": "Parquet",
				"typeProperties": {
					"location": {
						"type": "AzureBlobFSLocation",
						"fileName": {
							"value": "@dataset().p_file_name",
							"type": "Expression"
						},
						"folderPath": {
							"value": "@dataset().p_target_directory",
							"type": "Expression"
						},
						"fileSystem": {
							"value": "@dataset().p_target_container",
							"type": "Expression"
						}
					},
					"compressionCodec": "snappy"
				},
				"schema": []
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/linkedServices/ls_adls_ingestion')]"
			]
		},
		{
			"name": "[concat(parameters('factoryName'), '/ds_pgsql_ingest_audit')]",
			"type": "Microsoft.DataFactory/factories/datasets",
			"apiVersion": "2018-06-01",
			"properties": {
				"linkedServiceName": {
					"referenceName": "ls_postgres_ingestion",
					"type": "LinkedServiceReference"
				},
				"annotations": [],
				"type": "AzurePostgreSqlTable",
				"schema": [
					{
						"name": "audit_id",
						"type": "bigint",
						"precision": 0,
						"scale": 0
					},
					{
						"name": "run_id",
						"type": "uuid",
						"precision": 0,
						"scale": 0
					},
					{
						"name": "pipeline_name",
						"type": "character varying",
						"precision": 0,
						"scale": 0
					},
					{
						"name": "source_id",
						"type": "integer",
						"precision": 0,
						"scale": 0
					},
					{
						"name": "source_name",
						"type": "character varying",
						"precision": 0,
						"scale": 0
					},
					{
						"name": "file_name",
						"type": "text",
						"precision": 0,
						"scale": 0
					},
					{
						"name": "file_path",
						"type": "text",
						"precision": 0,
						"scale": 0
					},
					{
						"name": "status",
						"type": "character varying",
						"precision": 0,
						"scale": 0
					},
					{
						"name": "rows_processed",
						"type": "integer",
						"precision": 0,
						"scale": 0
					},
					{
						"name": "start_time",
						"type": "timestamp without time zone",
						"precision": 0,
						"scale": 0
					},
					{
						"name": "end_time",
						"type": "timestamp without time zone",
						"precision": 0,
						"scale": 0
					},
					{
						"name": "duration_seconds",
						"type": "integer",
						"precision": 0,
						"scale": 0
					},
					{
						"name": "retry_attempt",
						"type": "integer",
						"precision": 0,
						"scale": 0
					},
					{
						"name": "error_message",
						"type": "text",
						"precision": 0,
						"scale": 0
					},
					{
						"name": "trigger_type",
						"type": "character varying",
						"precision": 0,
						"scale": 0
					},
					{
						"name": "created_at",
						"type": "timestamp without time zone",
						"precision": 0,
						"scale": 0
					}
				],
				"typeProperties": {
					"schema": "ingestion",
					"table": "audit_ingestion_audit"
				}
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/linkedServices/ls_postgres_ingestion')]"
			]
		},
		{
			"name": "[concat(parameters('factoryName'), '/ls_adls_ingestion')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "AzureBlobFS",
				"typeProperties": {
					"url": "[parameters('ls_adls_ingestion_properties_typeProperties_url')]",
					"accountKey": {
						"type": "SecureString",
						"value": "[parameters('ls_adls_ingestion_accountKey')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/ls_postgres_ingestion')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "AzurePostgreSql",
				"version": "2.0",
				"typeProperties": {
					"server": "[parameters('ls_postgres_ingestion_properties_typeProperties_server')]",
					"port": "5432",
					"database": "[parameters('ls_postgres_ingestion_properties_typeProperties_database')]",
					"sslMode": 3,
					"username": "[parameters('ls_postgres_ingestion_properties_typeProperties_username')]",
					"password": {
						"type": "SecureString",
						"value": "[parameters('ls_postgres_ingestion_password')]"
					},
					"authenticationType": "Basic"
				}
			},
			"dependsOn": []
		}
	]
}